# Base de datos PostgreSQL local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/circuitos-turisticos

# API de OpenWeatherMap (opcional - obtener en https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# JWT: clave secreta para firmar tokens
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=pegar_aca_la_clave_generada
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
